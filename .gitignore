# Object Memory Assistant — .gitignore

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Virtual environments
venv/
.venv/
env/

# Model files (large — download via download_model.py)
models/*.pt
models/*.tflite
models/*.onnx

# Runtime data
data/frames/
data/database/
logs/
outputs/

# Secrets
.env

# Documentation
*.md

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Jupyter
*.ipynb
.ipynb_checkpoints/

# Training artefacts (do not commit)
WOTR/
WOTR_YOLO/
datasets/
runs/
